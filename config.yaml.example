# Switchboard Configuration
# Copy to config.yaml and customize as needed.
# All settings have sensible defaults — an empty config.yaml (or none at all) works fine.

# Server settings
port: 5001
host: "0.0.0.0"

# Project discovery — scans this directory for folders containing CLAUDE.md
# Default: parent directory of the switchboard install (auto-detected).
# Override to scan a different root:
# project_root: "~/projects"
scan_depth: 3

# Whether to include Switchboard itself in project discovery.
# Set to true if you develop Switchboard itself.
# Default: false (Switchboard hidden from project list and activity)
show_self: false

# tmux session settings
tmux_socket: "switchboard"
tmux_session: "switchboard"

# Claude Code model options shown in spawn dialog
# Set to "auto" (default) to discover models from `claude model list`.
# Or provide an explicit list:
#   models:
#     - id: "claude-sonnet-4-5"
#       label: "Sonnet 4.5"
#     - id: "claude-opus-4-6"
#       label: "Opus 4.6"
models: "auto"
default_model: "claude-opus-4-5"

# ─── System Monitor ───────────────────────────────────────────────
# Controls what appears in the Monitor tab (keyboard shortcut: m).
# CPU, memory, disk, network, and uptime are always shown (cross-platform).
# GPU and services are optional and configurable below.

monitor:
  # GPU monitoring
  # Auto-detects NVIDIA GPUs via nvidia-smi. Set enabled: false to hide the
  # GPU card entirely (e.g., on a Mac Mini or machine without a GPU).
  #
  # For non-NVIDIA setups, you can point to a custom command that outputs
  # three comma-separated values: utilization%, temperature°C, memory%.
  #
  # Examples:
  #   NVIDIA (default):  command: nvidia-smi
  #   AMD (rocm-smi):    command: /opt/rocm/bin/rocm-smi  (needs custom args)
  #   No GPU:            enabled: false
  gpu:
    enabled: true
    command: "nvidia-smi"
    args: "--query-gpu=utilization.gpu,temperature.gpu,utilization.memory,power.draw --format=csv,noheader,nounits"

  # Service monitoring — track any process by name
  # Each entry creates a card in Monitor showing the process's CPU% and RAM.
  # The "process" field is matched case-insensitively against running process names.
  # If the process isn't running, the card shows "--" for both metrics.
  #
  # Examples:
  #   - name: "Ollama"           # Card title
  #     process: "ollama"        # Process name to search for
  #   - name: "Postgres"
  #     process: "postgres"
  #   - name: "Docker"
  #     process: "dockerd"
  #   - name: "Open WebUI"
  #     process: "open-webui"
  services:
    - name: "Ollama"
      process: "ollama"

  # SMART disk health monitoring (Linux only)
  # Monitors NVMe drive health via smartctl. The card auto-hides if smartctl
  # is not installed or lacks permissions on the device.
  #
  # One-time permission setup:
  #   sudo setfacl -m u:<username>:r /dev/nvme0n1
  #
  # smart:
  #   device: "/dev/nvme0n1"     # Disk device for SMART monitoring
  #   cache_seconds: 300         # Re-check interval (default: 5 min)

  # Disk space monitoring — which mount point to track
  # Default: "/" (root filesystem). Change if your data lives elsewhere.
  # Examples:
  #   disk_path: "/"           # Root filesystem (default)
  #   disk_path: "/data"       # Separate data partition
  #   disk_path: "/mnt/storage"  # External storage
  disk_path: "/"

# ─── System Updates (Linux only) ──────────────────────────────────
# The Monitor tab can check for and apply apt/snap updates on Linux.
# This feature is automatically hidden on macOS and Windows.
#
# For apt updates to work non-interactively, configure passwordless sudo:
#   sudo visudo -f /etc/sudoers.d/switchboard-updates
#   <username> ALL=(ALL) NOPASSWD: /usr/bin/apt-get, /usr/bin/snap
#
# On macOS: use `brew update && brew outdated` manually. Switchboard
# doesn't manage macOS packages (yet).

# ─── Estimated API Cost Tracking ──────────────────────────────────
# The Usage tab shows estimated API costs based on token usage and model pricing.
# Useful for understanding what your usage would cost on API billing vs Max subscription.
#
# Pricing is per million tokens (USD). Update when Anthropic changes pricing
# or releases new model families. The compute script warns when it encounters
# a model ID that doesn't match any pricing config below.

pricing:
  subscription: 100  # Your monthly Max subscription cost (USD)
  models:
    claude-opus-4-5: { input: 5, output: 25 }
    claude-opus-4-6: { input: 5, output: 25 }
    claude-sonnet-4-5: { input: 3, output: 15 }
    claude-sonnet-4-6: { input: 3, output: 15 }
    claude-haiku-4-5: { input: 1, output: 5 }
  cache:
    read_discount: 0.90    # 90% off input price for cached reads
    creation_premium: 0.25  # 25% premium on input price for cache writes

# ─── Platform Dashboard Integration (optional) ───────────────────
# If your machine has a management dashboard API (e.g., DGX Spark),
# Switchboard can check for platform-level updates and trigger
# update+reboot from the Monitor tab.
# Leave commented out if your machine doesn't have a dashboard.
#
# spark:
#   url: "http://localhost:11000"   # Dashboard API URL
#   username: ""
#   password: ""
#   label: "Platform Update"        # Display name in Monitor (default: "Platform Update")
