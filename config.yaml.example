# Orchestrator Configuration
# Copy to config.yaml and customize as needed.
# All settings have sensible defaults — an empty config.yaml (or none at all) works fine.

# Server settings
port: 5001
host: "0.0.0.0"

# Project discovery — scans this directory for folders containing CLAUDE.md
project_root: "~"
scan_depth: 3

# tmux session settings
tmux_socket: "orchestrator"
tmux_session: "orchestrator"

# Claude Code model options shown in spawn dialog
# Update this list when new models are released
models:
  - id: "claude-sonnet-4-5-20250514"
    label: "Sonnet 4.5"
  - id: "claude-opus-4-5-20250514"
    label: "Opus 4.5"
  - id: "claude-sonnet-4-6"
    label: "Sonnet 4.6"
  - id: "claude-opus-4-6"
    label: "Opus 4.6"
default_model: "claude-opus-4-5-20250514"

# Optional: DGX Spark integration (system updates via Spark dashboard)
# spark:
#   url: http://localhost:11000
#   username: ""
#   password: ""
