[Unit]
Description=Orchestrator API + Web Server
After=network-online.target
Wants=network-online.target

[Service]
Type=forking
WorkingDirectory=%h/orchestrator
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/orchestrator/start.sh
ExecStop=%h/orchestrator/stop.sh
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
